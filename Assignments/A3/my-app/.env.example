# Environment Variables — Copy this file to .env and fill in your values

# MongoDB connection string
MONGODB_URI=mongodb://localhost:27017/realestate-crm

# JWT secret key (use a long random string in production)
JWT_SECRET=your-super-secret-jwt-key-here

# Email configuration (for Nodemailer — optional for core functionality)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password
